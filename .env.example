# PVE-QEMU-VirtIO-Updater Environment Configuration
# Copy this file to .env and customize as needed

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Directory where log files will be stored
# Default: <script_directory>/logs
# LOG_DIR=/var/log/pve-virtio-updater

# Logging level: debug, info, notice, warn, error, critical, alert, emergency
# Default: info
# LOG_LEVEL=info

# Log message format
# Available variables:
#   %d = date and time (YYYY-MM-DD HH:MM:SS)
#   %z = timezone (UTC or LOCAL)
#   %l = log level name (DEBUG, INFO, WARN, ERROR, etc.)
#   %s = script name
#   %m = message
# Default: [%d] [%l] %m
# LOG_FORMAT="[%d] [%l] %m"

# ============================================================================
# SVG NOTIFICATION CONFIGURATION
# ============================================================================

# Path to the SVG template file
# Default: <script_directory>/templates/svg/update-nag-template.svg
# SVG_IMAGE_TEMPLATE=/path/to/custom/template.svg

# ============================================================================
# NOTIFICATION CONFIGURATION
# ============================================================================

# Notification channels (comma-separated list). Supported values: smtp, msgraph, webhook
# Example: enable SMTP and webhook:
# NOTIFICATION_CHANNELS=smtp,webhook

# E-Mail Based Notifications:

# Email notification settings (SMTP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notifications@example.com
# SMTP_PASSWORD=your_password
# SMTP_FROM=pve-updater@example.com
#
# TLS is automatically derived from SMTP_PORT (standard IANA assignments):
#   25  -> opportunistic STARTTLS (smtp:// --ssl)
#   587 -> required STARTTLS     (smtp:// --ssl-reqd)   [default port]
#   465 -> implicit TLS          (smtps://)

# Email notification settings (Microsoft Graph)
# MSGRAPH_TENANT_ID=your_tenant_id
# MSGRAPH_CLIENT_ID=your_client_id
# MSGRAPH_CLIENT_SECRET=your_client_secret
# MSGRAPH_FROM=pve-updater@example.com

# Mail to is an Arry of email addresses to notify, if the E-Mail channel is configured.
# MAIL_TO=("Example admin <admin@example.com>" "Example support <support@example.com>")

# Webhook notification settings (outgoing — sends a POST to an external URL when updates are detected)
# WEBHOOK_URL=https://hooks.example.com/your-webhook
# WEBHOOK_METHOD=POST
# WEBHOOK_HEADERS='{"Content-Type": "application/json"}'

# ============================================================================
# WEBHOOK SERVER CONFIGURATION (inbound — adnanh/webhook)
# Runs a local HTTP server on the Proxmox host. Clicking the SVG nag banner
# in the Proxmox UI fires a request here, triggering vm-update.sh for that VM.
# This is separate from WEBHOOK_URL above, which sends outgoing notifications.
# ============================================================================

# Enable the webhook server integration (true/false)
# WEBHOOK_ENABLED=true

# IP or hostname of this Proxmox host — used to build clickable URLs in VM descriptions
# WEBHOOK_HOST=192.168.1.1

# Port the webhook binary listens on (default: 9000)
# WEBHOOK_PORT=9000

# Token appended as ?token= to authenticate click requests — change from the default!
# WEBHOOK_SECRET=changeme

# Systemd service name to restart after hooks.json changes
# WEBHOOK_SERVICE=pve-virtio-webhook.service

# ============================================================================
# CONTAINER MODE CONFIGURATION
# Set CONTAINER_MODE=true when running inside Docker.
# pvesh and qm are replaced by the pve-api.func shims (copied into lib/ by the
# Dockerfile). On bare-metal PVE hosts, leave this unset or set to false.
# ============================================================================

# Enable container mode (true/false)
# CONTAINER_MODE=true

# Proxmox VE REST API endpoint (required in container mode)
# Create an API token in PVE: Datacenter → Permissions → API Tokens → Add
# The token must have VM.Audit + VM.Config.Options + VM.GuestAgent privileges.
# PVE_HOST=pve.example.com
# PVE_PORT=8006
# PVE_API_TOKEN_ID=root@pam!updater
# PVE_API_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# TLS verification for the Proxmox API connection.
# Set PVE_TLS_INSECURE=true to skip certificate verification (self-signed certs).
# Or set PVE_CA_BUNDLE to verify against a custom CA bundle instead.
# Leave both unset to use the system trust store (recommended for production).
# PVE_TLS_INSECURE=false
# PVE_CA_BUNDLE=/etc/ssl/certs/my-ca.pem

# Timeouts for Proxmox API requests (seconds).
# PVE_API_CONNECT_TIMEOUT=10
# PVE_API_MAX_TIME=30

# Base URL for nag SVG images (must be reachable by the PVE web UI browser).
# In container mode this should point to the Caddy endpoint serving /app/images.
# On bare metal the default /pve2/images (served directly by PVE) is used.
# NAG_IMAGE_BASE_URL=http://updater.example.com:8080

# Path inside the container where SVG images are written (served by Caddy).
# SVG_IMAGE_PATH=/app/images

# How often to re-run the update check (seconds). Default: 3600 (1 hour).
# UPDATER_INTERVAL=3600

# ============================================================================
# ADVANCED CONFIGURATION FOR LOGGING (I recommend leaving these as defaults)
# ============================================================================

# Use UTC time in logs (true/false)
# Default: false
# USE_UTC=false

# Use systemd journal for logging (true/false)
# Default: true
# USE_JOURNAL=true

# Tag for systemd journal entries
# Default: PVE-VirtIO-Updater
# JOURNAL_TAG=PVE-VirtIO-Updater

# Enable console logging (true/false)
# Default: true
# CONSOLE_LOG=true

# Color settings for console output: auto, always, never
# Default: auto
# USE_COLORS=auto

# Environment variables for NO_COLOR and CLICOLOR standards
# NO_COLOR=1          # Set to disable colors
# CLICOLOR=0          # Set to 0 to disable colors
# CLICOLOR_FORCE=1    # Set to 1 to force colors
