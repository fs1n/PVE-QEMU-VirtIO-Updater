#!/usr/bin/env bash
#
# Module: notification.sh (PVE-QEMU-VirtIO-Updater)
# Description: Notification dispatcher supporting SMTP, Microsoft Graph, and webhook channels
# Author: Frederik S. (fs1n) and PVE-QEMU-VirtIO-Updater Contributors
# Date: 2025-01-31
#
# Dependencies: curl (for webhooks and SMTP) and jq
# Environment: NOTIFICATION_CHANNELS, SMTP_SERVER, MSGRAPH_TOKEN, WEBHOOK_URL
# Usage: source lib/notification.sh; notification_init; notification_send "subject" "body"
#
# Functions:
#   - notification_init: Initialize notification system and validate configuration
#   - notification_send: Dispatcher that routes to enabled channels
#   - notification_email_SMTP: Send email via SMTP
#   - notification_email_MSGRAPH: Send email via Microsoft Graph API
#   - notification_webhook: Send notification via webhook

# @function notification_init
# @description Initializes the notification system and validates required environment variables
# @args None
# @returns 0 on success, 1 if configuration missing
# @example
#   notification_init
function notification_init() {
    # Todo: Implement initialization logic here
    :
}

# @function notification_send
# @description Routes update notifications to all enabled channels defined in NOTIFICATION_CHANNELS
# @args subject body
# @returns 0 on successful dispatch to all channels (or if no channels are configured)
# @example
#   NOTIFICATION_CHANNELS="smtp,webhook" notification_send "Update completed" "All guests are now on the latest VirtIO drivers."
function notification_send() {
    local subject=${1-}
    local body=${2-}

    # If NOTIFICATION_CHANNELS is unset or empty, do nothing and succeed.
    if [[ -z "${NOTIFICATION_CHANNELS-}" ]]; then
        return 0
    fi

    local IFS=','
    read -ra CHANNELS <<< "$NOTIFICATION_CHANNELS"
    for channel in "${CHANNELS[@]}"; do
        case "$channel" in
            smtp) notification_email_SMTP "$subject" "$body" ;;
            msgraph) notification_email_MSGRAPH "$subject" "$body" ;;
            webhook) notification_webhook "$subject" "$body" ;;
        esac
    done
}

# @function notification_email_SMTP
# @description Sends email notification via SMTP (requires SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD, SMTP_FROM, MAIL_TO, SMTP_TLS_MODE configuration)
# @args subject body
# @returns 0 on success, 1 on failure
# @example
#   notification_email_SMTP "Update completed" "All guests are now on the latest VirtIO drivers."
function notification_email_SMTP() {
    local subject=${1-}
    local body=${2-}

    # Validate required configuration
    if [[ -z "${SMTP_HOST-}" ]] || [[ -z "${MAIL_TO-}" ]]; then
        echo "Error: SMTP_HOST and MAIL_TO are required" >&2
        return 1
    fi

    local smtp_port="${SMTP_PORT:-587}"
    local smtp_user="${SMTP_USER-}"
    local smtp_password="${SMTP_PASSWORD-}"

    # Build recipient flags
    local rcpt_args=()
    for addr in "${MAIL_TO[@]}"; do
        rcpt_args+=(--mail-rcpt "$addr")
    done

    # Build To header
    local to_header
    to_header=$(IFS=','; echo "${MAIL_TO[*]}")

    # Determine protocol and TLS flags from SMTP_TLS_MODE.
    # Port is independent of TLS mode means you could technicaly use port 443 with implicit TLS.
    #   none              -> smtp://, plaintext
    #   starttls          -> smtp:// + --ssl (opportunistic STARTTLS, negotiate)
    #   starttls-required -> smtp:// + --ssl-reqd (enforce STARTTLS, fail if unavailable)
    #   implicit          -> smtps:// (SSL/TLS from handshake start, e.g. port 465 or 443)
    local tls_mode="${SMTP_TLS_MODE:-starttls-required}"
    local protocol="smtp"
    local tls_flag=()

    case "$tls_mode" in
        none)
            protocol="smtp"
            tls_flag=()
            ;;
        starttls)
            protocol="smtp"
            tls_flag=(--ssl)
            ;;
        starttls-required)
            protocol="smtp"
            tls_flag=(--ssl-reqd)
            ;;
        implicit)
            protocol="smtps"
            tls_flag=()
            ;;
        *)
            echo "Error: Unknown SMTP_TLS_MODE '${tls_mode}'. Valid values: none, starttls, starttls-required, implicit" >&2
            return 1
            ;;
    esac

    # Build authentication flags
    local auth_flag=()
    if [[ -n "$smtp_user" && -n "$smtp_password" ]]; then
        auth_flag=(--user "${smtp_user}:${smtp_password}")
    fi

    # Send email
    curl --silent --show-error \
        --url "${protocol}://${SMTP_HOST}:${smtp_port}" \
        "${tls_flag[@]}" \
        "${auth_flag[@]}" \
        --mail-from "$SMTP_FROM" \
        "${rcpt_args[@]}" \
        --upload-file - <<EOF
From: $SMTP_FROM
To: $to_header
Subject: $subject
Date: $(date -R)
MIME-Version: 1.0
Content-Type: text/html; charset="UTF-8"

$body
EOF

    return $?
}

